{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "options": {
    "typeAware": true,
    "typeCheck": true
  },
  "plugins": [
    "eslint",
    "typescript",
    "jsdoc",
    "unicorn",
    "import",
    "node",
    "promise"
  ],
  "env": {
    "node": true,
    "es2022": true
  },
  "ignorePatterns": [
    "dist/**",
    "build/**",
    "logs/**",
    "coverage/**",
    "*.min.js",
    ".wrangler/**",
    "tests/code-quality.test.ts",
    "tests/input-validation.test.ts",
    "tests/security-fixes.test.ts",
    "release.config.mjs",
    "cli/release.config.mjs"
  ],
  "rules": {
    // ---- The Absolute Errors (Backend & Event Loop Safety) ----
    "typescript/no-var-requires": "error",
    "typescript/no-require-imports": "error",
    "node/no-new-require": "error",
    "promise/catch-or-return": "error",
    "import/no-cycle": "error",

    // ---- The Boy Scout Protocol (TypeScript Strictness) ----
    "typescript/no-explicit-any": "warn",
    "typescript/no-non-null-assertion": "warn",
    "typescript/ban-ts-comment": "warn",
    "typescript/explicit-module-boundary-types": "warn",

    // Type-Aware Rules (Powered by tsgo)
    "typescript/no-floating-promises": "warn",
    "typescript/no-misused-promises": "warn",
    "typescript/await-thenable": "warn",
    "typescript/no-unsafe-assignment": "warn",
    "typescript/no-unsafe-member-access": "warn",
    "typescript/no-unsafe-call": "warn",
    "typescript/no-unsafe-argument": "warn",
    "typescript/no-unsafe-return": "warn",
    "typescript/no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_"
      }
    ],

    // ---- JSDoc Strictness (Native) ----
    // Only rules implemented in oxlint 1.70's native jsdoc plugin are listed.
    // Unsupported rules (check-alignment, check-indentation, check-param-names,
    // check-syntax, check-types, require-description) were removed — oxlint 1.70
    // fails config parsing on unknown rule names.
    "jsdoc/check-tag-names": "warn",
    "jsdoc/require-param": "warn",
    "jsdoc/require-param-description": "warn",
    "jsdoc/require-param-type": "warn",
    "jsdoc/require-returns": "warn",
    "jsdoc/require-returns-description": "warn",
    "jsdoc/require-returns-type": "warn"
  }
}
