{
  "name": "Ubuntu + Bun + Node + Docker",
  "image": "vikshan/ubuntu-bun-node:latest",

  // Add Docker-in-Docker feature
  "features": {
    // "ghcr.io/devcontainers/features/docker-in-docker:2": {
    //   "moby": true,
    //   "azureDnsAutoDetection": true,
    //   "installDockerBuildx": true,
    //   "version": "latest",
    //   "dockerDashComposeVersion": "v2"
    // },
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },

  // Configure tool-specific properties.
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "oven.bun-vscode",
        "ms-azuretools.vscode-docker",
        "WakaTime.vscode-wakatime",
        "mongodb.mongodb-vscode",
        "coderabbit.coderabbit-vscode",
        "DeepScan.vscode-deepscan"
      ]
    }
  },

  // // Mount docker socket and enable privileged mode for Docker-in-Docker
  // "privileged": true,
  // "mounts": ["source=dind-var-lib-docker,target=/var/lib/docker,type=volume"],

  "remoteUser": "root",
  "postCreateCommand": "apt update && apt upgrade -y && bun upgrade && ln -sf /usr/share/zoneinfo/Africa/Nairobi /etc/localtime && curl -fsSL https://cli.coderabbit.ai/install.sh | sh && mkdir -p scripts && curl -sL https://raw.githubusercontent.com/iamvikshan/.github/main/scripts/bootstrap.sh > scripts/bootstrap.sh && chmod +x scripts/bootstrap.sh && scripts/bootstrap.sh --default"
}
