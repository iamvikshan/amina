{
  "name": "mina-api",
  "version": "1.0.0",
  "description": "Amina REST API - Cloudflare Workers (Hono + MongoDB)",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build:prd": "bun install --frozen-lockfile",
    "dev:local": "bun run --hot src/server.ts",
    "deploy": "wrangler deploy",
    "deploy:prd": "bunx wrangler deploy --env production",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.3",
    "hono": "^4.12.21",
    "mongodb": "^7.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260520.1",
    "wrangler": "^4.93.0"
  }
}
