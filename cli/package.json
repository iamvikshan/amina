{
  "name": "amina",
  "version": "1.0.0",
  "description": "CLI tool for deploying, updating, and managing Amina Discord bot instances",
  "keywords": [
    "discord",
    "bot",
    "cli",
    "deployment",
    "docker",
    "amina",
    "discord-bot",
    "vps"
  ],
  "type": "module",
  "license": "CC-BY-4.0",
  "homepage": "https://github.com/iamvikshan/amina#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamvikshan/amina.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/iamvikshan/amina/issues/new/choose"
  },
  "bin": {
    "amina": "./dist/index.js"
  },
  "files": [
    "dist/index.js"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "bun": ">=1.3.11"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --entry-naming index.js",
    "postbuild": "bun -e \"import { readFileSync, writeFileSync, chmodSync } from 'node:fs'; const p = 'dist/index.js', c = readFileSync(p, 'utf8'); if (!c.startsWith('#!')) writeFileSync(p, '#!/usr/bin/env bun\\n' + c); chmodSync(p, 0o755)\"",
    "build:linux-x64": "bun build src/index.ts --compile --target bun-linux-x64 --outfile dist/amina-linux-x64",
    "build:linux-arm64": "bun build src/index.ts --compile --target bun-linux-arm64 --outfile dist/amina-linux-arm64",
    "build:darwin-x64": "bun build src/index.ts --compile --target bun-darwin-x64 --outfile dist/amina-darwin-x64",
    "build:darwin-arm64": "bun build src/index.ts --compile --target bun-darwin-arm64 --outfile dist/amina-darwin-arm64",
    "build:windows-x64": "bun build src/index.ts --compile --target bun-windows-x64 --outfile dist/amina-windows-x64.exe",
    "prepublishOnly": "bun run build && bun run postbuild",
    "check": "bunx tsc --project tsconfig.json --noEmit",
    "test": "bun test tests/"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "chalk": "^5.6.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  }
}
