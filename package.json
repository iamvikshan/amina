{
  "name": "amina",
  "version": "3.3.10",
  "description": "An open-source, multipurpose discord bot built using discord-js",
  "main": "src/index.ts",
  "author": "vikshan",
  "license": "CC-BY-4.0",
  "engines": {
    "bun": ">=1.3.11"
  },
  "workspaces": [
    "api"
  ],
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "lint:fix": "eslint . --fix",
    "check": "eslint . && tsc --noEmit",
    "f": "(git diff --name-only --diff-filter=ACMR HEAD && git ls-files --others --exclude-standard) | grep -E '\\.(Dockerfile|yaml|yml|ts|tsx|js|jsx|json|css|md|mjs)$' | xargs bunx prettier --write --ignore-unknown",
    "f:all": "prettier --write .",
    "f:check": "prettier --check .",
    "api:dev": "bun --filter 'mina-api' dev",
    "api:check": "bun --filter 'mina-api' check",
    "api:deploy": "bun --filter 'mina-api' deploy",
    "check:all": "bun check && bun api:check",
    "prepare": "test -d .git && husky || true",
    "bs": "mkdir -p scripts && curl -sL https://raw.githubusercontent.com/iamvikshan/.github/main/scripts/bootstrap.sh > scripts/bootstrap.sh && chmod +x scripts/bootstrap.sh && scripts/bootstrap.sh",
    "upd": "apt update && apt upgrade -y && bun upgrade && bun update --latest && bun i && bun f:all"
  },
  "homepage": "https://github.com/iamvikshan/amina#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamvikshan/amina.git"
  },
  "bugs": {
    "url": "https://github.com/iamvikshan/amina/issues/new/choose"
  },
  "dependencies": {
    "@honeybadger-io/js": "^6.14.0",
    "@vitalets/google-translate-api": "^9.2.1",
    "axios": "^1.18.0",
    "common-tags": "^1.8.2",
    "dayjs": "^1.11.21",
    "discord-gamecord": "^4.4.4",
    "discord-giveaways": "^6.0.1",
    "discord-together": "^1.4.2",
    "discord.js": "^14.26.4",
    "enhanced-ms": "^5.0.0",
    "lavalink-client": "^2.10.2",
    "lru-cache": "^11.5.1",
    "module-alias": "^2.3.4",
    "mongoose": "^9.7.0",
    "openai": "^6.42.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pretty-ms": "^9.3.0",
    "sourcebin_js": "^0.0.3-ignore",
    "string-progressbar": "^1.0.4",
    "table": "^6.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/bun": "^1.3.14",
    "@types/common-tags": "^1.8.4",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^10.5.0",
    "eslint-plugin-jsdoc": "^63.0.2",
    "husky": "^9.1.7",
    "prettier": "3.8.4",
    "semantic-release": "^25.0.5",
    "semantic-release-gitmoji": "^1.6.9",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "discord",
    "discord.js",
    "discord-bot",
    "open-source",
    "bot",
    "multipurpose",
    "multi-purpose-bot"
  ]
}
