{
  "name": "amina",
  "version": "3.3.11",
  "description": "An open-source, multipurpose discord bot built using discord-js",
  "keywords": [
    "bot",
    "discord",
    "discord-bot",
    "discord.js",
    "multi-purpose-bot",
    "multipurpose",
    "open-source"
  ],
  "homepage": "https://github.com/iamvikshan/amina#readme",
  "bugs": {
    "url": "https://github.com/iamvikshan/amina/issues/new/choose"
  },
  "license": "CC-BY-4.0",
  "author": "vikshan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamvikshan/amina.git"
  },
  "workspaces": [
    "api"
  ],
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "f": "oxfmt --write .",
    "f:check": "oxfmt --check .",
    "lint:fix": "oxlint --fix .",
    "lint": "oxlint .",
    "type": "tsgo --noEmit",
    "check": "bun run type && bun run lint",
    "api:dev": "bun --filter 'mina-api' dev",
    "api:check": "bun --filter 'mina-api' type",
    "api:deploy": "bun --filter 'mina-api' deploy",
    "check:all": "bun check && bun api:check",
    "prepare": "test -d .git && husky || true",
    "bs": "mkdir -p scripts && curl -sL https://raw.githubusercontent.com/iamvikshan/.github/main/scripts/bootstrap.sh > scripts/bootstrap.sh && chmod +x scripts/bootstrap.sh && scripts/bootstrap.sh",
    "upd": "apt update && apt upgrade -y && bun upgrade && bun update --latest && bun i && bun f"
  },
  "dependencies": {
    "@honeybadger-io/js": "^6.14.0",
    "@vitalets/google-translate-api": "^9.2.1",
    "axios": "^1.18.0",
    "common-tags": "^1.8.2",
    "dayjs": "^1.11.21",
    "discord-gamecord": "^4.4.4",
    "discord-giveaways": "^6.0.1",
    "discord-together": "^1.4.2",
    "discord.js": "^14.26.4",
    "enhanced-ms": "^5.0.0",
    "lavalink-client": "^2.10.3",
    "lru-cache": "^11.5.1",
    "module-alias": "^2.3.4",
    "mongoose": "^9.7.1",
    "openai": "^6.44.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pretty-ms": "^9.3.0",
    "sourcebin_js": "^0.0.3-ignore",
    "string-progressbar": "^1.0.4",
    "table": "^6.9.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/bun": "^1.3.14",
    "@types/common-tags": "^1.8.4",
    "@typescript/native-preview": "^7.0.0-dev.20260621.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "semantic-release": "^25.0.5",
    "semantic-release-gitmoji": "^1.6.9"
  },
  "engines": {
    "bun": ">=1.3.11"
  }
}
