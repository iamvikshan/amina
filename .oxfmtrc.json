{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "endOfLine": "lf",
  "arrowParens": "avoid",
  "bracketSpacing": true,
  "htmlWhitespaceSensitivity": "css",
  "insertPragma": false,
  "jsxSingleQuote": true,
  "printWidth": 80,
  "proseWrap": "always",
  "quoteProps": "as-needed",
  "requirePragma": false,
  "semi": false,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "useTabs": false,
  "overrides": [
    {
      "files": ["*.md", "*.yml", "*.yaml"],
      "options": {
        "proseWrap": "preserve"
      }
    },
    {
      "files": ["*.json", "*.jsonc"],
      "options": {
        "trailingComma": "none",
        "singleQuote": false
      }
    }
  ],
  "ignorePatterns": [
    // Build & Package Noise
    "node_modules/",
    "dist/",
    "*.lock",
    
    // Logs & Git
    "logs/",
    "*.log",
    ".git/",
    
    // IDEs
    ".vscode/",
    ".idea/",
    
    // Binary & Media Files (from your find output)
    "*.png",
    "*.svg",
    
    // Husky Autogenerated Scripts
    "husky/_/**",
    ".husky/_/**",
    
    // Specific Exclusions (from your legacy prettierignore)
    "types/**",
    "CHANGELOG.md",
    "tests/**"
  ]
}