{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "types": ["@types/bun"],
    "verbatimModuleSyntax": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "sourceMap": true,
    "inlineSources": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "paths": {
      "@root/*": ["./*"],
      "@data/*": ["./src/data/*"],
      "@handlers/*": ["./src/handlers/*"],
      "@helpers/*": ["./src/helpers/*"],
      "@schemas/*": ["./src/database/schemas/*"],
      "@src/*": ["./src/*"],
      "@structures/*": ["./src/structures/*"],
      "@commands/*": ["./src/commands/*"],
      "@types/*": ["./types/*"],
      "@services/*": ["./src/services/*"]
    }
  },
  "include": [
    "src/**/*", 
    "types/**/*", 
    "tests/**/*",
    "*.js", 
    "*.mjs",
    "scripts/**/*.sh"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "logs",
    "api", // Completely isolates the API workspace from the root compilation
    "types/api/**/*",
    "tests/code-quality.test.ts",
    "tests/input-validation.test.ts",
    "tests/security-fixes.test.ts"
  ]
}