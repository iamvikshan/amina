{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":semanticCommits"],
  "semanticCommitType": "chore",
  "baseBranchPatterns": ["main"],

  "automerge": true,
  "minimumReleaseAge": "1 day",

  "prConcurrentLimit": 10,
  "prHourlyLimit": 5,
  "labels": ["dependencies"],
  "assignees": ["iamvikshan"],
  "schedule": ["before 4am every weekday"],
  "timezone": "Africa/Nairobi",
  "dependencyDashboard": true,
  "dependencyDashboardApproval": false,
  "rebaseWhen": "conflicted",
  "rangeStrategy": "bump",
  "separateMinorPatch": true,
  "separateMajorMinor": true,

  "packageRules": [
    {
      "description": "Scope API dependency updates so they don't trigger bot releases",
      "matchFileNames": ["api/**"],
      "additionalBranchPrefix": "api-",
      "semanticCommitScope": "api",
      "groupName": "api dependencies"
    },
    {
      "description": "Require manual approval for major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "minimumReleaseAge": "5 days",
      "labels": ["dependencies", "major-update"]
    },
    {
      "description": "Wait a bit longer to automerge production minor updates",
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Require manual approval for the discord.js ecosystem",
      "groupName": "discord.js ecosystem",
      "matchPackageNames": ["/^discord\\.js/", "/^@discordjs/"],
      "automerge": false,
      "minimumReleaseAge": "5 days"
    },
    {
      "description": "Group Dockerfile base images and wait 3 days before automerging",
      "groupName": "Dockerfile base images",
      "matchManagers": ["dockerfile"],
      "minimumReleaseAge": "3 days"
    }
  ],

  "lockFileMaintenance": {
    "enabled": true,
    "minimumReleaseAge": "0 days",
    "schedule": ["before 4am on monday"]
  },
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "minimumReleaseAge": "0 days"
  }
}
